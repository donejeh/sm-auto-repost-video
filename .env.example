# App
APP_SECRET_KEY=change-me-generate-with-secrets-token-urlsafe-32
APP_ENV=development
APP_URL=http://localhost:5173
API_URL=http://localhost:8000

# Database
DATABASE_URL=sqlite:///./data/autovideo.db

# Queue (optional locally — inline worker fallback when unset)
# REDIS_URL=redis://localhost:6379

# Storage & logging
STORAGE_PATH=storage
LOG_DIR=logs
LOG_LEVEL=INFO
MAX_UPLOAD_MB=500

# Session
SESSION_LIFETIME_HOURS=24

# Meta OAuth (Facebook Login + Instagram Graph)
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:8000/api/oauth/meta/callback

# Google OAuth (YouTube Data API)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/oauth/google/callback

# Fallback API tokens (optional — for headless publish without OAuth UI)
INSTAGRAM_GRAPH_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
FACEBOOK_PAGE_ID=

# yt-dlp cookies (Netscape format — export while logged in)
YTDLP_COOKIES_FILE=cookies-youtube.txt
INSTAGRAM_COOKIES_FILE=cookies-instagram.txt

# Optional AI caption generation
# Anthropic-compatible API (works with api.anthropic.com or a compatible proxy)
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-20250514
OPENAI_API_KEY=
GROQ_API_KEY=

# Encrypt OAuth tokens at rest (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
TOKEN_ENCRYPTION_KEY=
